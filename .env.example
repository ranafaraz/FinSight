# FinSight runs fully offline by default. Everything below is OPTIONAL and only
# needed if you want real (paid/download) backends. Copy to `.env` to use.

# --- Sentiment backend ---
# lexical (default, offline) | finbert (needs: pip install "finsight[finbert]")
FINSIGHT_SENTIMENT_BACKEND=lexical

# --- Data backend ---
# synthetic (default, offline, deterministic) | csv | yfinance (needs "[market]")
FINSIGHT_DATA_BACKEND=synthetic

# --- Synthetic market controls (deterministic; tweak for experiments) ---
# FINSIGHT_SEED=7
# FINSIGHT_N_ASSETS=12
# FINSIGHT_N_DAYS=756
# FINSIGHT_SIGNAL_BETA=0.0032
# FINSIGHT_SENTIMENT_PERSISTENCE=0.6
# FINSIGHT_COST_PER_TURN=0.0010
